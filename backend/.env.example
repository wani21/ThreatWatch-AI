# ThreatWatch-AI Application Configuration

# App Configuration
APP_NAME="ThreatWatch-AI"
APP_ENV="development"
DEBUG=true
SECRET_KEY="generate-a-secure-secret-key-for-production"

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=threatwatch_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy Database URL (used for database connections)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/threatwatch_ai
